{
  "name": "senlis-participatif-api",
  "version": "0.1.0",
  "private": true,
  "description": "API REST — Senlis Participatif",
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch src/index.js",
    "start": "node --env-file-if-exists=.env src/index.js",
    "postinstall": "prisma generate",
    "seed": "node --env-file-if-exists=.env prisma/seed.js",
    "migrate:test": "dotenv -e .env.test -- npx prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.0",
    "pg": "^8.22.0",
    "sharp": "^0.35.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.19.0",
    "dotenv": "^17.2.0",
    "prisma": "7.8.0",
    "supertest": "^7.1.0",
    "vitest": "^4.1.9"
  }
}

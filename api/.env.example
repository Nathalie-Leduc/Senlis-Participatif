# ══════════════════════════════════════════════════════════════
# Senlis Participatif — Variables d'environnement API
# Copier ce fichier en .env et compléter les valeurs.
# ⚠️ Ne JAMAIS commiter le .env (il est dans .gitignore)
# ══════════════════════════════════════════════════════════════

# ── Base de données ──────────────────────────────────────────
DATABASE_URL=postgresql://senlis:senlis_dev_password@localhost:5432/senlis_participatif

# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Client (CORS + liens dans les emails) ────────────────────
CLIENT_URL=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACER_PAR_64_CARACTERES_ALEATOIRES
JWT_EXPIRES_IN=7h

# ── Email (Mailtrap en dev, Brevo en prod) ───────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=votre_user_mailtrap
SMTP_PASS=votre_pass_mailtrap
EMAIL_FROM=Senlis Participatif <no-reply@senlis-participatif.fr>

# ── Jetons email ─────────────────────────────────────────────
TOKEN_TTL_MINUTES=60
